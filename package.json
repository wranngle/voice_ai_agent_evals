{
  "name": "@wranngle/voice-evals",
  "version": "1.1.0",
  "description": "Research-stage eval and regression harness for ElevenLabs voice agents: WAV barge-in and VAD scoring, LLM-judge rubrics (G-Eval), baseline diffs, and synthetic-conversation ingestion. Bun-first TypeScript.",
  "type": "module",
  "license": "MIT",
  "author": "Wranngle Systems LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/wranngle/voice-evals.git"
  },
  "homepage": "https://github.com/wranngle/voice-evals#readme",
  "bugs": {
    "url": "https://github.com/wranngle/voice-evals/issues"
  },
  "keywords": [
    "elevenlabs",
    "voice-ai",
    "voice-agent",
    "conversational-ai",
    "eval",
    "evaluation",
    "regression-testing",
    "llm-as-judge",
    "g-eval",
    "audio-native",
    "barge-in",
    "tts",
    "asr",
    "agent-testing",
    "bun",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wrapper": {
      "types": "./dist/wrapper/index.d.ts",
      "import": "./dist/wrapper/index.js"
    },
    "./tests-api": {
      "types": "./dist/wrapper/tests.d.ts",
      "import": "./dist/wrapper/tests.js"
    },
    "./scoring": {
      "types": "./dist/scoring/index.d.ts",
      "import": "./dist/scoring/index.js"
    },
    "./ingestion": {
      "types": "./dist/ingestion/index.d.ts",
      "import": "./dist/ingestion/index.js"
    },
    "./regression": {
      "types": "./dist/regression/index.d.ts",
      "import": "./dist/regression/index.js"
    },
    "./remediation": {
      "types": "./dist/remediation/index.d.ts",
      "import": "./dist/remediation/index.js"
    },
    "./factory": {
      "types": "./dist/factory/index.d.ts",
      "import": "./dist/factory/index.js"
    },
    "./n8n": {
      "types": "./dist/n8n/index.d.ts",
      "import": "./dist/n8n/index.js"
    },
    "./scenarios": {
      "types": "./dist/scenarios/index.d.ts",
      "import": "./dist/scenarios/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "voice-evals": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@elevenlabs/react": "1.6.3",
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-three/drei": "^9",
    "@react-three/fiber": "^8",
    "@types/three": "0.184.1",
    "arktype": "2.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.3.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "1.16.0",
    "motion": "12.40.0",
    "next-themes": "0.4.6",
    "react": "18",
    "react-day-picker": "10.0.1",
    "react-dom": "18",
    "react-hook-form": "7.76.1",
    "react-resizable-panels": "4.11.2",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "three": "0.184.0",
    "use-stick-to-bottom": "1.1.4",
    "vaul": "1.1.2",
    "yaml": "2.8.4",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@elevenlabs/elevenlabs-js": "2.49.1"
  },
  "peerDependenciesMeta": {
    "@elevenlabs/elevenlabs-js": {
      "optional": false
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "axe-core": "4.11.4",
    "bun-types": "1.3.13",
    "playwright": "1.60.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "xo": "1.2.3"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test:offline && bun run build",
    "postinstall": "node ./scripts/postinstall.mjs",
    "doctor": "bun run src/cli.ts doctor",
    "eval": "bun run src/eval/run.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:offline": "vitest run --project ingestion --project integration --project governance --project templates --project agent_evals --project elevenlabs --project n8n-eval --project mcp --project wrapper --project scoring --project ingestion-llm --project regression --project remediation --project cli --project factory --project n8n --project report --project log --project scenarios --project refinement --project compare --project fuzz --project budget --project replay --project leaderboard --project _meta_audit",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:webhook": "vitest --project webhook",
    "test:fuzz": "vitest --project fuzz",
    "fuzz:inject": "bun run src/fuzz/cli.ts",
    "test:elevenlabs": "vitest --project elevenlabs",
    "test:n8n-eval": "vitest --project n8n-eval",
    "test:mcp": "vitest --project mcp",
    "testing": "bun run src/cli.ts",
    "testing:run": "bun run src/cli.ts run",
    "testing:list": "bun run src/cli.ts list",
    "testing:validate": "bun run src/cli.ts validate",
    "testing:report": "bun run src/cli.ts report",
    "testing:ingest": "bun run src/cli.ts ingest",
    "testing:live": "bun run scripts/test-elevenlabs-runner.ts && bun run scripts/test-n8n-eval-runner.ts && bun run scripts/test-mcp-runner.ts",
    "testing:live:el": "bun run scripts/test-elevenlabs-runner.ts",
    "testing:live:n8n": "bun run scripts/test-n8n-eval-runner.ts",
    "testing:live:mcp": "bun run scripts/test-mcp-runner.ts",
    "testing:gtm-ops": "bun run scripts/run-gtm-ops-adapter.ts",
    "compare": "bun run src/compare/cli.ts",
    "demo:compare": "bun run src/compare/cli.ts --runs examples/compare/run-aria.json,examples/compare/run-nova.json --out out/compare.html",
    "leaderboard": "bun run src/leaderboard/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "xo",
    "lint:fix": "xo --fix",
    "playground": "bun run playground/server.ts",
    "playground:verify": "bun run playground/verify-all.mjs"
  }
}
