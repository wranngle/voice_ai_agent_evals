{
  "name": "voice_ai_agents",
  "version": "1.0.0",
  "type": "module",
  "xo": {
    "space": 2,
    "semicolon": true,
    "prettier": false,
    "rules": {
      "unicorn/no-process-exit": "off",
      "unicorn/prefer-top-level-await": "off",
      "unicorn/prevent-abbreviations": "off",
      "unicorn/no-null": "off",
      "unicorn/prefer-module": "off",
      "unicorn/prefer-node-protocol": "off",
      "unicorn/no-anonymous-default-export": "off",
      "@typescript-eslint/consistent-type-definitions": "off",
      "@typescript-eslint/naming-convention": "off",
      "@typescript-eslint/no-unsafe-assignment": "off",
      "@typescript-eslint/no-unsafe-call": "off",
      "@typescript-eslint/no-unsafe-member-access": "off",
      "@typescript-eslint/no-unsafe-return": "off",
      "@typescript-eslint/no-unsafe-argument": "off",
      "@typescript-eslint/no-explicit-any": "off",
      "@typescript-eslint/no-require-imports": "off",
      "@typescript-eslint/ban-ts-comment": "off",
      "@typescript-eslint/prefer-nullish-coalescing": "off",
      "@typescript-eslint/no-redundant-type-constituents": "off",
      "@typescript-eslint/restrict-template-expressions": "off",
      "n/prefer-global/process": "off",
      "n/file-extension-in-import": "off",
      "import/extensions": "off",
      "no-await-in-loop": "off",
      "max-depth": "off",
      "complexity": "off",
      "capitalized-comments": "off"
    },
    "overrides": [
      {
        "files": [
          "hooks/**/*.ts"
        ],
        "rules": {
          "unicorn/no-process-exit": "off"
        }
      },
      {
        "files": [
          "**/*.test.ts",
          "**/*.spec.ts"
        ],
        "rules": {
          "@typescript-eslint/no-unsafe-assignment": "off",
          "@typescript-eslint/no-explicit-any": "off"
        }
      }
    ]
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:offline": "vitest run --project ingestion --project integration --project governance",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:webhook": "vitest --project webhook",
    "test:elevenlabs": "vitest --project elevenlabs",
    "test:n8n-eval": "vitest --project n8n-eval",
    "test:mcp": "vitest --project mcp",
    "testing": "bun run lib/testing/cli.ts",
    "testing:run": "bun run lib/testing/cli.ts run",
    "testing:list": "bun run lib/testing/cli.ts list",
    "testing:validate": "bun run lib/testing/cli.ts validate",
    "testing:report": "bun run lib/testing/cli.ts report",
    "testing:ingest": "bun run lib/testing/cli.ts ingest",
    "test:report": "npx allure serve allure-results",
    "test:report:generate": "npx allure generate allure-results -o reports/allure --clean",
    "testing:live": "bun run scripts/test-elevenlabs-runner.ts && bun run scripts/test-n8n-eval-runner.ts && bun run scripts/test-mcp-runner.ts",
    "testing:live:el": "bun run scripts/test-elevenlabs-runner.ts",
    "testing:live:n8n": "bun run scripts/test-n8n-eval-runner.ts",
    "testing:live:mcp": "bun run scripts/test-mcp-runner.ts",
    "typecheck": "tsc --noEmit",
    "lint": "xo",
    "lint:fix": "xo --fix"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "allure-js-commons": "3.4.5",
    "allure-vitest": "3.4.5",
    "arktype": "2.1.29",
    "bun-types": "1.3.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "xo": "1.2.3"
  }
}
