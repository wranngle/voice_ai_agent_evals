#!/bin/sh
# Pre-push hook: Run tests before pushing

cd workflows/voice_ai_agents || exit 0

echo "Running voice AI agent tests..."
bun run test:offline

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Push blocked."
  echo "Run 'bun run test:offline' in workflows/voice_ai_agents to see details."
  exit 1
fi

echo "✅ Offline tests passed. Pushing."
