# voice_ai_agent_evals - Git Ignore

# ===================
# CREDENTIALS & SECRETS
# ===================
.env
.env.*
!.env.example
credentials*.json
secrets*.json
*.key
*.pem

# Real ElevenLabs/Twilio agent registry — operator-local; placeholder version is the only public form
agent-registry.yaml
!agent-registry.example.yaml

# n8n cloud instance dumps — never re-commit (operator-local)
workflows_list.json

# OpenSpec working state (proposals churn — keep specs/ only)
openspec/changes/

# ===================
# TEMPORARY & DEBUG FILES
# ===================
*.tmp
*.temp
*.bak
*.backup
temp-*.json
temp_*.json
test-payload*.json
current-agent-config.json
clean-agent-config.json
enriched-config*.json
minimal-workflow.json
exec.json
response.txt
deploy-response.json
webhook-response.json

# ===================
# NODE.JS
# ===================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
bun.lock

# ===================
# TYPESCRIPT
# ===================
*.tsbuildinfo
dist/
build/

# ===================
# IDE & EDITORS
# ===================
.vscode/
.idea/
*.sublime-*

# ===================
# OS FILES
# ===================
.DS_Store
Thumbs.db
desktop.ini

# ===================
# LOGS
# ===================
*.log
logs/

# ===================
# TEST RESULTS
# ===================
*-results-*.json
test-results/
baseline-results-*.json
nightmare-results-*.json
regression-results-*.json
agent-audit-*.json

# ===================
# CLAUDE & BMAD (keep commands/ committed; ignore operator-local state)
# ===================
.claude/local/
.claude/worktrees/
.claude/mcp.json
.claude/.env
.claude/settings.json
.claude/scheduled_tasks*
.claude/logs/
.claude-controlled
.gemini/local/
.gemini/settings.json
_bmad-output/
.bmad-output/

# ===================
# Playwright MCP runtime artifacts
# ===================
.playwright-mcp/

# ===================
# Husky auto-managed (we use lefthook now — lefthook.yml is committed)
# ===================
.husky/_/

# ===================
# WORKING DIRECTORIES
# ===================
temp/
old/
exported_conversations/
.absorbed/
.archived-workflows/
