{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.wranngle.com/voice-evals/tool-calls/transfer_to_agent.schema.json",
  "title": "transfer_to_agent",
  "description": "Live-call transfer to a human or escalation queue.",
  "type": "object",
  "additionalProperties": false,
  "required": ["queue", "reason"],
  "properties": {
    "queue": {
      "type": "string",
      "enum": ["billing", "support", "sales", "supervisor"]
    },
    "reason": {
      "type": "string",
      "minLength": 3,
      "maxLength": 500
    },
    "warm_transfer": {
      "type": "boolean"
    },
    "caller_id": {
      "type": "string",
      "pattern": "^\\+[1-9][0-9]{6,14}$"
    }
  }
}
