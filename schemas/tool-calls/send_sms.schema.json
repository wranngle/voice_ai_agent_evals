{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.wranngle.com/voice-evals/tool-calls/send_sms.schema.json",
  "title": "send_sms",
  "description": "Outbound SMS sent from the agent via the post-call follow-up tool. Recorded from the ElevenLabs post-call webhook (same source as the round-1 latency waterfall capture).",
  "type": "object",
  "additionalProperties": false,
  "required": ["to", "body"],
  "properties": {
    "to": {
      "type": "string",
      "description": "E.164 phone number.",
      "pattern": "^\\+[1-9][0-9]{6,14}$"
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1600
    },
    "from": {
      "type": "string",
      "pattern": "^\\+[1-9][0-9]{6,14}$"
    },
    "media_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
