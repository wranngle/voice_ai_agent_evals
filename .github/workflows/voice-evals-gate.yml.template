# voice-evals merge gating workflow (template)
#
# Copy this file into your repo as `.github/workflows/voice-evals-gate.yml`
# to block merges whose voice-eval success rate drops below the configured
# threshold.
#
# ⚠️  The package is NOT published to npm (research stage — see README
#     "Status"), so anything `bunx '@wranngle/voice-evals…'`-shaped will 404.
#     The steps below run the harness FROM SOURCE: they check out
#     wranngle/voice_ai_agent_evals next to your repo and invoke
#     `bun src/cli.ts run -t scenario --json`.
#
# What the gate actually runs: the OFFLINE scenario fixtures COMMITTED IN
# YOUR REPO under `tests/scenarios/<id>/scenario.yaml` (discovered from the
# working directory — authoring guide: docs/extending-the-harness.md in the
# harness repo; canonical examples under its own tests/scenarios/). It emits
# a summary JSON shaped `{total_tests, passed, failed, ...}` and the jq step
# gates on `passed / total_tests`. No secrets are required — the scenario
# runner is fixture-driven and never calls the ElevenLabs API. (A future
# live-gate mode would need ELEVENLABS_API_KEY; the gate-native
# `voice-evals score --fixtures --min-success-rate` CLI is a v1.2 target.)
#
# Note: with zero committed fixtures the CLI itself exits 1 with
# `{"error":"no tests matched type=scenario","total_tests":0}` — the `|| true`
# + explicit total check below turn that into a readable fail-closed verdict
# instead of a bare nonzero exit.
#
# Optional env (override at the workflow_dispatch level if needed):
#   VOICE_EVALS_MIN_SUCCESS_RATE  — pass-rate floor, defaults to `0.9` (90%)

name: voice-evals-gate

on:
  pull_request:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pull-requests: write

concurrency:
  group: voice-evals-gate-${{ github.ref }}
  cancel-in-progress: true

jobs:
  gate:
    runs-on: ubuntu-latest
    env:
      VOICE_EVALS_MIN_SUCCESS_RATE: '0.9'
    steps:
      - uses: actions/checkout@v4
        with:
          persist-credentials: false

      - name: checkout the voice-evals harness (not on npm — run from source)
        uses: actions/checkout@v4
        with:
          repository: wranngle/voice_ai_agent_evals
          path: .voice-evals-harness
          persist-credentials: false

      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      - name: install harness dependencies
        working-directory: .voice-evals-harness
        run: bun install --frozen-lockfile

      - name: run committed scenario fixtures and emit gate verdict
        id: score
        run: |
          # The CLI exits 1 itself when zero fixtures match `-t scenario`
          # (targeted-filter guard) — capture the summary either way so the
          # verdict below is readable instead of a bare nonzero exit.
          bun .voice-evals-harness/src/cli.ts run -t scenario --json \
            > voice-evals-summary.json || true
          total=$(jq -r '.total_tests // 0' voice-evals-summary.json)
          passed=$(jq -r '.passed // 0' voice-evals-summary.json)
          if [ "$total" -eq 0 ]; then
            echo "gate: no scenario fixtures found under tests/scenarios/ — failing closed"
            echo "gate: commit at least one tests/scenarios/<id>/scenario.yaml (see docs/extending-the-harness.md in the harness repo)"
            exit 1
          fi
          rate=$(jq -n "$passed / $total")
          echo "gate: $passed/$total passed (rate $rate, floor $VOICE_EVALS_MIN_SUCCESS_RATE)"
          jq -en "$rate >= $VOICE_EVALS_MIN_SUCCESS_RATE" > /dev/null

      - name: upload report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: voice-evals-report
          path: voice-evals-summary.json
          if-no-files-found: warn

      - name: comment on PR when gate fails
        if: failure() && github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const body = [
              'voice-evals gate failed — success rate below '
                + `${process.env.VOICE_EVALS_MIN_SUCCESS_RATE}.`,
              '',
              'See the `voice-evals-report` artifact for the per-fixture breakdown.',
            ].join('\n');
            await github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body,
            });
