# voice-evals merge gating workflow (template) — PREVIEW
#
# Copy this file into your repo as `.github/workflows/voice-evals-gate.yml`
# to block merges whose voice-eval success rate drops below the configured
# threshold. Pinned to the `@wranngle/voice-evals@v1` major tag — bumping the
# tag is an explicit opt-in to breaking changes.
#
# ⚠️  Forward-looking interface. `voice-evals score --fixtures <dir>
#     --min-success-rate <rate> --json-summary <file>` is the v1.2 gate-native
#     CLI shape and is NOT shipped in v1.1.x. Today's `voice-evals score`
#     accepts a single WAV positional + `--html-out` / `--run-id` /
#     `--json-log`. Until the gate CLI lands, use one of these alternatives:
#
#       a) `bunx '@wranngle/voice-evals@1' legacy run -t scenario --json`
#          — runs the offline scenario fixtures and emits a `summary` JSON
#          with `{total, passed, failed, errors, skipped}`. Threshold-gate
#          against `.summary.passed / .summary.total` with jq.
#       b) Drive `voice-evals score <wav>` per fixture from a shell loop and
#          aggregate exit codes.
#
#     Treat this template as the contract we're landing in v1.2.
#
# Required repo secrets:
#   ELEVENLABS_API_KEY            — read-only key for the agent under test
#   VOICE_EVALS_AGENT_ID          — id of the ElevenLabs Conversational AI agent
#
# Optional env (override at the workflow_dispatch level if needed):
#   VOICE_EVALS_FIXTURES_DIR      — defaults to `.test-data` (planned v1.2)
#   VOICE_EVALS_MIN_SUCCESS_RATE  — defaults to `0.9` (90%) (planned v1.2)

name: voice-evals-gate

on:
  pull_request:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pull-requests: write

concurrency:
  group: voice-evals-gate-${{ github.ref }}
  cancel-in-progress: true

jobs:
  gate:
    runs-on: ubuntu-latest
    env:
      VOICE_EVALS_MIN_SUCCESS_RATE: '0.9'
      VOICE_EVALS_FIXTURES_DIR: .test-data
    steps:
      - uses: actions/checkout@v4
        with:
          persist-credentials: false

      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      - name: install voice-evals (v1 major)
        run: bunx --bun '@wranngle/voice-evals@v1' --version

      - name: score fixtures and emit gate verdict
        id: score
        env:
          ELEVENLABS_API_KEY: ${{ secrets.ELEVENLABS_API_KEY }}
          VOICE_EVALS_AGENT_ID: ${{ secrets.VOICE_EVALS_AGENT_ID }}
        run: |
          bunx --bun '@wranngle/voice-evals@v1' score \
            --fixtures "$VOICE_EVALS_FIXTURES_DIR" \
            --min-success-rate "$VOICE_EVALS_MIN_SUCCESS_RATE" \
            --json-summary voice-evals-summary.json

      - name: upload report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: voice-evals-report
          path: voice-evals-summary.json
          if-no-files-found: warn

      - name: comment on PR when gate fails
        if: failure() && github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const body = [
              'voice-evals gate failed — success rate below '
                + `${process.env.VOICE_EVALS_MIN_SUCCESS_RATE}.`,
              '',
              'See the `voice-evals-report` artifact for the per-fixture breakdown.',
            ].join('\n');
            await github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body,
            });
