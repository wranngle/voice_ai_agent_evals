# voice_ai_agent_evals — Environment Configuration
# Copy this file to .env and fill in your values.
# Helper scripts also read ~/.agents/.env (process.env wins on conflict).
#
# Variables marked [HARNESS-READS] are read by code in this repo.
# Variables marked [CONVENTION] are operator-side names referenced in docs
# and templates (agent-registry.example.yaml, webhook-security.md, etc.) —
# the harness itself does not load them, but downstream receivers do.

# ===================================
# ElevenLabs (voice agent platform)
# ===================================
# [HARNESS-READS] Required for live ElevenLabs runner + check-elevenlabs-agent script.
ELEVENLABS_API_KEY=
# [HARNESS-READS] Default agent ID for runner scripts when not passed via flag.
ELEVENLABS_AGENT_ID=
# [HARNESS-READS] Override the ElevenLabs API base URL (factory client-builder).
# Default: https://api.elevenlabs.io. Set for staging / self-hosted gateways.
ELEVENLABS_BASE_URL=
# [HARNESS-READS] Test-runner default for ELEVENLABS_POST_CALL_SECRET — the
# webhook runner verifies post-call signatures against this in tests
# (src/testing/runners/webhook-runner.ts).
ELEVENLABS_POST_CALL_SECRET=
# [HARNESS-READS] Provisioned by `voice-evals webhooks provision/rotate` and
# read by `voice-evals webhooks status` + the production receiver. Distinct
# from ELEVENLABS_POST_CALL_SECRET above — that one is the test-runner
# default; this one is what the CLI manages for a live deployment.
ELEVENLABS_POST_CALL_WEBHOOK_SECRET=

# ===================================
# n8n (workflow orchestration — optional)
# ===================================
# [HARNESS-READS] Required for n8n-eval / mcp runner scripts and live n8n test commands.
N8N_API_KEY=
N8N_API_URL=
# [HARNESS-READS] Required by `voice-evals n8n` CLI (workflow auto-corrector).
# Distinct from N8N_API_URL above — that one is used by the test runners +
# webhooks CLI; the corrector module reads N8N_BASE_URL. Both can point at
# the same n8n install (`https://your-n8n/api/v1`); a future cleanup may
# unify the two names.
N8N_BASE_URL=
# [CONVENTION] Shared secret your n8n receiver verifies on incoming tool/post-call calls.
N8N_WEBHOOK_SECRET=
# [HARNESS-READS] Default webhook URL used by client-initiation tests.
N8N_WEBHOOK_URL=
# [HARNESS-READS] Workflow ID + webhook path of a deployed post-call workflow you want to evaluate.
N8N_POST_CALL_WORKFLOW_ID=
N8N_POST_CALL_WEBHOOK_PATH=post-call

# ===================================
# SMS tool (webhook-fronted — optional)
# ===================================
# [HARNESS-READS] URL the SMS-tool tests post to (in tests, the local mock; in prod, your webhook host).
SMS_WEBHOOK_URL=
# [HARNESS-READS] Shared secret expected by the SMS webhook receiver.
SMS_WEBHOOK_SECRET=

# ===================================
# Post-call webhook (for tests)
# ===================================
# [HARNESS-READS] URL of the deployed post-call webhook receiver under test.
POST_CALL_WEBHOOK_URL=

# ===================================
# Agent registry tool URLs
# ===================================
# [CONVENTION] Referenced as ${TOOL_*_URL} placeholders in agent-registry.example.yaml.
# Substituted at deploy time by your own templating, not by the harness.
TOOL_LOOKUP_URL=
TOOL_SEND_SMS_URL=

# ===================================
# Agent evals
# ===================================
# [HARNESS-READS] Tunables for lib/agent_evals/config/settings.ts. All optional.
AGENT_EVALS_MAX_TURN_DURATION_MS=
AGENT_EVALS_MIN_AGENT_TURN_RATIO=
AGENT_EVALS_LOG_FILE=
AGENT_EVALS_METRICS_ENDPOINT=

# ===================================
# Runner scripts
# ===================================
# [HARNESS-READS] Comma-separated keywords expected in agent responses
# (used by scripts/test-elevenlabs-runner.ts).
EXPECT_RESPONSE_CONTAINS=

# ===================================
# Tests
# ===================================
# [HARNESS-READS] Storage dir override for integration tests; default: ./.test-data
TEST_STORAGE_DIR=

# ===================================
# LLM provider (refine + rubric judges)
# ===================================
# [HARNESS-READS] Path to llm.sh (the Gemini-provider-chain CLI). If unset,
# voice-evals refine probes PATH for `llm.sh`. Required for `--no-llm`-off
# runs unless GEMINI_API_KEY is provided as fallback (see refine.ts).
LLM_SH=
# [HARNESS-READS] Direct Gemini key. Used as the fallback LlmCompleteCallback
# in `voice-evals refine` when llm.sh isn't on PATH and no callback is
# injected. SDK consumers should inject their own callback instead.
GEMINI_API_KEY=
# [HARNESS-READS] Google AI Studio key — alternate slot read by
# src/refinement/llm-provider.ts. Use either GEMINI_API_KEY or GOOGLE_API_KEY;
# the provider prefers GEMINI_API_KEY when both are set.
GOOGLE_API_KEY=
# [HARNESS-READS] Override the model used by the refine LLM judge. Defaults
# to the top-of-`code` ranking in ~/.agents/model-rankings.json. Pin only
# when reproducibility against a specific model is required.
REFINE_JUDGE_MODEL=

# ===================================
# Result pipeline (where eval outputs ship)
# ===================================
# [HARNESS-READS] HTTPS endpoint for shipping eval results (run summaries +
# scenario results). Read by src/cli/commands/webhooks.ts and the post-call
# ingestion path.
EVALS_INGEST_URL=
# [HARNESS-READS] HTTPS endpoint for shipping audio artifacts (WAV files
# associated with scored runs). Read by the webhooks CLI + deploy-n8n-workflows.
AUDIO_SINK_URL=
# [HARNESS-READS] HTTPS endpoint for routing alert events (eval-failure /
# threshold-breach pings). Read by the webhooks CLI + deploy-n8n-workflows.
ALERT_WEBHOOK_URL=
# [HARNESS-READS] HTTPS endpoint that the agent_evals runtime CLI posts run
# notifications to (src/agent_evals/runtime/cli.ts + src/notify/webhook.ts).
VOICE_EVALS_NOTIFY_WEBHOOK_URL=

# ===================================
# Harness behavior toggles
# ===================================
# [HARNESS-READS] Set to "1" to suppress JSONL trace emission to
# logs/voice-evals-<date>.jsonl (src/internal/jsonl-trace.ts +
# scripts/lib/jsonl-trace.mjs). Useful for CI runs where the trace stream
# would noisy up the artifact bundle.
VOICE_EVALS_DISABLE_TRACE=
# [HARNESS-READS] Set to "1" to skip the Python sidecar install during
# postinstall (Phase 5.x GEPA install runs `uv` to create a venv +
# `gepa_run.py`). Set in CI runners that don't have `uv` available.
VOICE_EVALS_SKIP_PYTHON_INSTALL=
