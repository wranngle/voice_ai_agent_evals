# voice_ai_agent_evals — Environment Configuration
# Copy this file to .env and fill in your values.
# Helper scripts also read ~/.agents/.env (process.env wins on conflict).

# ===================================
# ElevenLabs (voice agent platform)
# ===================================
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Optional human-readable agent name used by some helper scripts when ELEVENLABS_AGENT_ID is unset.
ELEVENLABS_AGENT_NAME=
# HMAC secret used to verify ElevenLabs post-call webhooks.
ELEVENLABS_POST_CALL_SECRET=

# ===================================
# Twilio (telephony)
# ===================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ===================================
# n8n (workflow orchestration)
# ===================================
N8N_API_KEY=
N8N_API_URL=
# Shared secret sent as X-Webhook-Secret on every outgoing call to n8n webhooks.
N8N_WEBHOOK_SECRET=
# Default webhook URL used by tests/scripts (e.g. client-initiation, post-call).
N8N_WEBHOOK_URL=
# Base URL for tabular n8n webhooks (e.g. https://your-n8n-host.example.com/webhook).
N8N_WEBHOOK_BASE_URL=
# Workflow ID + webhook path of a deployed post-call workflow you want to evaluate.
N8N_POST_CALL_WORKFLOW_ID=
N8N_POST_CALL_WEBHOOK_PATH=post-call

# ===================================
# SMS tool (webhook-fronted)
# ===================================
# URL the SMS tool posts to (in tests, the local mock; in prod, your webhook host).
SMS_WEBHOOK_URL=
# Shared secret expected by the SMS webhook receiver.
SMS_WEBHOOK_SECRET=

# ===================================
# Post-call webhook (for tests)
# ===================================
POST_CALL_WEBHOOK_URL=

# ===================================
# Agent registry tool URLs
# ===================================
# Referenced as ${TOOL_*_URL} placeholders in agent-registry.example.yaml.
TOOL_LOOKUP_URL=
TOOL_SEND_SMS_URL=

# ===================================
# Agent evals
# ===================================
# Tunables for lib/agent_evals/config/settings.ts. All optional.
AGENT_EVALS_MAX_TURN_DURATION_MS=
AGENT_EVALS_MIN_AGENT_TURN_RATIO=
AGENT_EVALS_FIXTURES_DIRECTORY=
AGENT_EVALS_LOG_FILE=
AGENT_EVALS_OTLP_ENDPOINT=

# ===================================
# Tests
# ===================================
# Override placeholder secret used by webhook integration tests.
TEST_API_KEY=
# Storage dir override for integration tests; default: ./.test-data
TEST_STORAGE_DIR=
